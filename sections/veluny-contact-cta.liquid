{% comment %}
  VeLuny "Talk to Us" — a breath before the footer, not a feature section.
  design-system.md §4.5. Deliberately minimal: heading, short richtext,
  one button. No scroll animation, no block repeater — per the design
  system's own note not to overbuild this one.

  Placeholder copy below is written in the support voice from
  VeLuny-Brand-Guide.md §4 ("patient, human, zero jargon") to preview
  on-brand — not final copy, and the email address is a placeholder too.
{% endcomment %}

{{ 'veluny-contact-cta.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .veluny-contact-cta-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .veluny-contact-cta-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="veluny-contact-cta veluny-contact-cta-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width veluny-contact-cta__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="veluny-contact-cta__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <div class="veluny-contact-cta__text rte">{{ section.settings.text }}</div>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a
        {% if section.settings.button_link != blank %}
          href="{{ section.settings.button_link }}"
        {% else %}
          role="link" aria-disabled="true"
        {% endif %}
        class="button"
      >
        {{ section.settings.button_label | escape }}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "VeLuny Talk to Us",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "Placeholder copy and email — written to match the support voice (Brand Guide §4: patient, human, zero jargon) so the section previews on-brand. Not final; swap the email for a real support address before launch."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Still have a question?"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>We’re real people, happy to help — no hold music, no jargon, just a straight answer. Reach out any time.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Email Us"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "info": "Defaults to mailto:hello@veluny.com in this preset — a placeholder support address."
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "veluny-warm-sand",
          "label": "VeLuny Warm Sand"
        },
        {
          "value": "veluny-blush-nap",
          "label": "VeLuny Blush Nap"
        }
      ],
      "default": "veluny-warm-sand",
      "label": "Color scheme",
      "info": "Warm Sand or Blush Nap only — pick one, per the accent rule (never both in a section)."
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 128,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 96
    }
  ],
  "presets": [
    {
      "name": "VeLuny Talk to Us"
    }
  ]
}
{% endschema %}
