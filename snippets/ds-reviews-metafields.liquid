{{ 'component-reviews.css' | asset_url | stylesheet_tag }}
{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}
{% capture author_1 %}
  {% if product.metafields.custom.review_1_author_name != blank %}
    {{ product.metafields.custom.review_1_author_name }}
  {% elsif product.metafields.custom.hide_review_1_author_name != true %}
    Enter the name of the customer who provided this
    review. If you don’t have a real name, use a generic one like "Happy
    Customer."
  {% endif %}
{% endcapture %}
{% capture author_2 %}
  {% if product.metafields.custom.review_2_author_name != blank %}
    {{ product.metafields.custom.review_2_author_name }}
  {% elsif product.metafields.custom.hide_review_2_author_name != true %}
    Enter the name of the customer who provided this
    review. If you don’t have a real name, use a generic one like "Happy
    Customer."
  {% endif %}
{% endcapture %}
{% capture author_3 %}
  {% if product.metafields.custom.review_3_author_name != blank %}
    {{ product.metafields.custom.review_3_author_name }}
  {% elsif product.metafields.custom.hide_review_3_author_name != true %}
    Enter the name of the customer who provided this
    review. If you don’t have a real name, use a generic one like "Happy
    Customer."
  {% endif %}
{% endcapture %}
{% capture text_1 %}
  {% if product.metafields.custom.review_1_text != blank %}
    {{ product.metafields.custom.review_1_text }}
  {% elsif product.metafields.custom.hide_review_1_text != true %}
    Add a customer review highlighting the product’s benefits,
    quality, or experience. Keep it natural and engaging to build trust with
    shoppers.  
  {% endif %}
{% endcapture %}
{% capture text_2 %}
  {% if product.metafields.custom.review_2_text != blank %}
    {{ product.metafields.custom.review_2_text }}
  {% elsif product.metafields.custom.hide_review_2_text != true %}
    Add a customer review highlighting the product’s benefits,
    quality, or experience. Keep it natural and engaging to build trust with
    shoppers.
  {% endif %}
{% endcapture %}
{% capture text_3 %}
  {% if product.metafields.custom.review_3_text != blank %}
    {{ product.metafields.custom.review_3_text }}
  {% elsif product.metafields.custom.hide_review_3_text != true %}
    Add a customer review highlighting the product’s benefits,
    quality, or experience. Keep it natural and engaging to build trust with
    shoppers.  
  {% endif %}
{% endcapture %}


<div class="review-items-container" style="--star-color:{{ block.settings.star_color }};--margin-top: {{ block.settings.margin_top | divided_by: 10.0 }}rem;--margin-bottom: {{ block.settings.margin_bottom | divided_by: 10.0 }}rem;">
  {%- assign items_count = 0 -%}
  {%- if text_1 != blank or author_1 != blank -%}
    {%- assign items_count = items_count | plus: 1 -%}
  {%- endif -%}
  {%- if text_2 != blank or author_2 != blank -%}
    {%- assign items_count = items_count | plus: 1 -%}
  {%- endif -%}
  {%- if text_3 != blank or author_3 != blank -%}
    {%- assign items_count = items_count | plus: 1 -%}
  {%- endif -%}

  <slideshow-component
    class="slider-mobile-gutter"
    role="region"
    aria-roledescription="{{ 'sections.slideshow.carousel' | t }}"
    aria-label="Customer reviews"
  >
    <div
      class="slideshow banner grid grid--1-col slider slider--everywhere"
      id="Slider-{{ section.id }}"
      aria-live="polite"
      aria-atomic="true"
      data-autoplay="false"
      data-speed="5"
    >
      {%- unless text_1 == blank and author_1 == blank -%}
        <div
          class="slideshow__slide grid__item grid--1-col slider__slide"
          id="Slide-{{ section.id }}-1"
          {{ block.shopify_attributes }}
          role="group"
          aria-roledescription="{{ 'sections.slideshow.slide' | t }}"
          aria-label="1 {{ 'general.slider.of' | t }} 3"
          tabindex="-1"
        >
          <div class="review-item review-item--{{ block.settings.avatar_alignment }}">
            {%- unless block.settings.image_1 == blank -%}
              <div class="review-item__image">
                <img
                  src="{{ block.settings.image_1 | image_url }}"
                  alt="{{ author_1 }}"
                  width="auto"
                  height="auto"
                  loading="lazy"
                >
              </div>
            {%- endunless -%}
            <div class="review-item__right">
              <div class="review-item__text">
                {{ text_1 }}
              </div>
              {%- unless author_1 == blank and block.settings.display_stars == false -%}
                <div class="review-item__author-and-stars">
                  {%- unless author_1 == blank -%}
                    <p class="review-item__author">
                      {{ author_1 }}
                    </p>
                  {%- endunless -%}
                  {%- if block.settings.display_stars -%}
                    <span class="review-item__stars">★★★★★</span>
                  {%- endif -%}
                </div>
              {%- endunless -%}
            </div>
          </div>
        </div>
      {%- endunless -%}
      {%- unless text_2 == blank and author_2 == blank -%}
        <div
          class="slideshow__slide grid__item grid--1-col slider__slide"
          id="Slide-{{ section.id }}-2"
          {{ block.shopify_attributes }}
          role="group"
          aria-roledescription="{{ 'sections.slideshow.slide' | t }}"
          aria-label="2 {{ 'general.slider.of' | t }} 3"
          tabindex="-1"
        >
          <div class="review-item review-item--{{ block.settings.avatar_alignment }}">
            {%- unless block.settings.image_2 == blank -%}
              <div class="review-item__image">
                <img
                  src="{{ block.settings.image_2 | image_url }}"
                  alt="{{ author_2 }}"
                  width="auto"
                  height="auto"
                  loading="lazy"
                >
              </div>
            {%- endunless -%}
            <div class="review-item__right">
              <div class="review-item__text">
                {{ text_2 }}
              </div>
              {%- unless author_2 == blank and block.settings.display_stars == false -%}
                <div class="review-item__author-and-stars">
                  {%- unless author_2 == blank -%}
                    <p class="review-item__author">
                      {{ author_2 }}
                    </p>
                  {%- endunless -%}
                  {%- if block.settings.display_stars -%}
                    <span class="review-item__stars">★★★★★</span>
                  {%- endif -%}
                </div>
              {%- endunless -%}
            </div>
          </div>
        </div>
      {%- endunless -%}

      {%- unless text_3 == blank and author_3 == blank -%}
        <div
          class="slideshow__slide grid__item grid--1-col slider__slide"
          id="Slide-{{ section.id }}-1"
          {{ block.shopify_attributes }}
          role="group"
          aria-roledescription="{{ 'sections.slideshow.slide' | t }}"
          aria-label="3 {{ 'general.slider.of' | t }} 3"
          tabindex="-1"
        >
          <div class="review-item review-item--{{ block.settings.avatar_alignment }}">
            {%- unless block.settings.image_3 == blank -%}
              <div class="review-item__image">
                <img
                  src="{{ block.settings.image_3 | image_url }}"
                  alt="{{ author_3 }}"
                  width="auto"
                  height="auto"
                  loading="lazy"
                >
              </div>
            {%- endunless -%}
            <div class="review-item__right">
              <div class="review-item__text">
                {{ text_3 }}
              </div>
              {%- unless author_3 == blank and block.settings.display_stars == false -%}
                <div class="review-item__author-and-stars">
                  {%- unless author_3 == blank -%}
                    <p class="review-item__author">
                      {{ author_3 }}
                    </p>
                  {%- endunless -%}
                  {%- if block.settings.display_stars -%}
                    <span class="review-item__stars">★★★★★</span>
                  {%- endif -%}
                </div>
              {%- endunless -%}
            </div>
          </div>
        </div>
      {%- endunless -%}
    </div>

    {%- if items_count > 1 -%}
      <div class="slideshow__controls slider-buttons no-js-hidden slideshow__controls--border-radius-mobile">
        <button
          type="button"
          class="slider-button slider-button--prev"
          name="previous"
          aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}"
          aria-controls="Slider-{{ section.id }}"
        >
          {% render 'ds-icon-caret' %}
        </button>
        <div class="slider-counter slider-counter--dots">
          <div class="slideshow__control-wrapper">
            {%- unless text_1 == blank and author_1 == blank -%}
              <button
                class="slider-counter__link slider-counter__link--dots link"
                aria-label="{{ 'sections.slideshow.load_slide' | t }} 1 {{ 'general.slider.of' | t }} 3"
                aria-controls="Slider-{{ section.id }}"
              >
                <span class="dot"></span>
              </button>
            {%- endunless -%}
            {%- unless text_2 == blank and author_2 == blank -%}
              <button
                class="slider-counter__link slider-counter__link--dots link"
                aria-label="{{ 'sections.slideshow.load_slide' | t }} 2 {{ 'general.slider.of' | t }} 3"
                aria-controls="Slider-{{ section.id }}"
              >
                <span class="dot"></span>
              </button>
            {%- endunless -%}
            {%- unless text_3 == blank and author_3 == blank -%}
              <button
                class="slider-counter__link slider-counter__link--dots link"
                aria-label="{{ 'sections.slideshow.load_slide' | t }} 3 {{ 'general.slider.of' | t }} 3"
                aria-controls="Slider-{{ section.id }}"
              >
                <span class="dot"></span>
              </button>
            {%- endunless -%}
          </div>
        </div>
        <button
          type="button"
          class="slider-button slider-button--next"
          name="next"
          aria-label="{{ 'sections.slideshow.next_slideshow' | t }}"
          aria-controls="Slider-{{ section.id }}"
        >
          {% render 'ds-icon-caret' %}
        </button>
      </div>
    {%- endif -%}
    <noscript>
      {%- if items_count > 1 -%}
        <div class="slider-buttons">
          <div class="slider-counter">
            {%- unless text_1 == blank and author_1 == blank -%}
              <a
                href="#Slide-{{ section.id }}-1"
                class="slider-counter__link link"
                aria-label="{{ 'sections.slideshow.load_slide' | t }} 1 {{ 'general.slider.of' | t }} 3"
              >
                1
              </a>
            {%- endunless -%}
            {%- unless text_2 == blank and author_2 == blank -%}
              <a
                href="#Slide-{{ section.id }}-2"
                class="slider-counter__link link"
                aria-label="{{ 'sections.slideshow.load_slide' | t }} 2 {{ 'general.slider.of' | t }} 3"
              >
                2
              </a>
            {%- endunless -%}
            {%- unless text_3 == blank and author_3 == blank -%}
              <a
                href="#Slide-{{ section.id }}-3"
                class="slider-counter__link link"
                aria-label="{{ 'sections.slideshow.load_slide' | t }} 3 {{ 'general.slider.of' | t }} 3"
              >
                3
              </a>
            {%- endunless -%}
          </div>
        </div>
      {%- endif -%}
    </noscript>
  </slideshow-component>
</div>

{%- if request.design_mode -%}
  <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
{%- endif -%}
